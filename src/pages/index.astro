---
import Layout from "@layouts/Layout.astro";

import About from "@/components/sections/About.astro";
import Experience from "@/components/sections/Experience.astro";
import Hero from "@/components/sections/Hero.astro";
import Projects from "@/components/sections/Projects.astro";
import Skills from "@/components/sections/Skills.astro";
import KeyboardManager from "@/components/KeyboardManager.astro";
import ThemeSwitch from "@/components/ThemeSwitch.astro";

import CV, { basics } from "@cv";
import Education from "@/components/sections/Education.astro";
import NeovimButton from "../components/neovim/Button.astro";
const { name} = basics;
---

<Layout title={`${name} - Portfolio`}>
  <main
    class="relative grid grid-cols-1 h-full max-w-7xl gap-12 p-8 max-sm:gap-8 max-sm:px-4 max-sm:py-16 md:min-h-screen md:grid-cols-6 md:p-16 xl:gap-24 text-skin-base print:gap-4"
  >
    <div
      class="slide-enter space-y-6 ease-in md:col-span-2 print:grid print:grid-cols-5 print:space-y-0"
    >
      <Hero className="col-span-2" />
      <About className="col-span-3" />
      <ThemeSwitch />
      <NeovimButton />
    </div>
    <div
      class="slide-enter-content space-y-12 md:col-span-4 print:grid print:grid-cols-5 print:grid-flow-row print:gap-2 print:space-y-0"
    >
      <Experience className="print:col-span-3" />
      {
        (
          <>
            <Projects className="print:hidden" />
            {CV?.education && <Education className="order-first print:col-span-2" />}
            <Skills className="print:col-span-full" />
          </>
        )
      }
    </div>
  </main>
  <KeyboardManager />
</Layout>

<style>
  .scrollbar-thin::-webkit-scrollbar {
    height: 8px;
  }
  .scrollbar-thumb-gray-400::-webkit-scrollbar-thumb {
    background-color: #a0aec0;
    border-radius: 4px;
  }
</style>

<style is:global>
  * {
    scrollbar-color: var(--color-button-muted) var(--color-fill);
  }
  @page {
    size: auto;
    margin: 0;
  }
  main {
    margin: auto;
    width: 100%;
  }

  /* ----------------------------------------------------------------------
     Print layout — robust, single-column document.
     A CSS grid two-column layout cannot paginate cleanly: when one column
     is taller than a page the grid row is split at an arbitrary point.
     For print we collapse the whole page into one predictable top-to-bottom
     flow that paginates correctly regardless of how large each section is.
     ---------------------------------------------------------------------- */
  @media print {
    /* A zero page margin makes the browser drop its default header/footer
       (the date + document title Chrome injects when printing). The visual
       margins are restored with padding on <main> below. */
    @page {
      margin: 0;
    }

    /* Clean white sheet — printer-friendly and crisp regardless of theme. */
    body {
      background: #fff !important;
    }

    /* Strip interactive/dev chrome that must never reach the PDF. */
    astro-dev-toolbar,
    .c-cursor,
    .footer-button,
    #normal-footer {
      display: none !important;
    }

    /* The PDF must never depend on entry-animation state (opacity/transform).
       Without this, headless/early prints capture half-faded content. */
    .slide-enter,
    .slide-enter-content > * {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }

    /* Collapse the responsive grid into a single full-width column. */
    main {
      display: block !important;
      max-width: 100% !important;
      min-height: 0 !important;
      margin: 0 !important;
      padding: 1.3cm 1.4cm !important;
      /* Apply the page padding to EVERY page fragment (not just the first),
         so pages 2+ also get top/bottom breathing room while @page margin
         stays 0 to keep the browser's header/footer suppressed. */
      -webkit-box-decoration-break: clone;
      box-decoration-break: clone;
    }
    main > div {
      display: block !important;
      width: 100% !important;
    }
    /* Even vertical rhythm between every stacked section. */
    main > div > * + *,
    main > div + div {
      margin-top: 1.15rem !important;
    }

    /* Follow document order in the printed sheet. The on-screen layout uses
       `order-*` utilities (e.g. order-first on the nested Certificates section)
       that would otherwise shuffle a linear printed document — reset them so
       Education entries print before Certificates, as authored. */
    section {
      order: 0 !important;
    }

    /* Keep a section/entry heading with the content that follows it. */
    h3,
    h4 {
      break-after: avoid-page;
    }

    /* The custom cursor (GSAP) writes inline transform/box-shadow/background
       onto whatever element is hovered. If the pointer happens to sit over an
       element when printing, that hover style bleeds into the PDF. Reset it. */
    [data-ccursor] {
      transform: none !important;
      box-shadow: none !important;
      background-image: none !important;
      filter: none !important;
      scale: none !important;
    }

    /* Certificates collapse to one compact line: "Name - Issuer (Year)". */
    .cert-list li {
      display: block;
    }
    .cert-list li > div {
      display: inline;
    }
    .cert-list h3,
    .cert-list h3 > a,
    .cert-list .relative > div,
    .cert-list time {
      display: inline;
      position: static;
      margin: 0;
    }
    .cert-list h3::after {
      content: " - ";
      font-weight: 400;
    }
    .cert-list time::before {
      content: " (";
    }
    .cert-list time::after {
      content: ")";
    }
  }

  @keyframes slide-enter {
    0% {
      transform: translateY(10px);
      opacity: 0;
    }

    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .slide-enter,
    .slide-enter-content > *:not(:has(.table-of-contents)) {
      --enter-stage: 0;
      --enter-step: 150ms;
      --enter-initial: 0ms;
      animation: slide-enter 1s both 1;
      animation-delay: calc(
        var(--enter-initial) + var(--enter-stage) * var(--enter-step)
      );
    }

    .slide-enter-content > *:nth-child(1) {
      --enter-stage: 1 !important;
    }
    .slide-enter-content > *:nth-child(2) {
      --enter-stage: 2 !important;
    }
    .slide-enter-content > *:nth-child(3) {
      --enter-stage: 3 !important;
    }
    .slide-enter-content > *:nth-child(4) {
      --enter-stage: 4 !important;
    }
    .slide-enter-content > *:nth-child(5) {
      --enter-stage: 5 !important;
    }
    .slide-enter-content > *:nth-child(6) {
      --enter-stage: 6 !important;
    }
    .slide-enter-content > *:nth-child(7) {
      --enter-stage: 7 !important;
    }
    .slide-enter-content > *:nth-child(8) {
      --enter-stage: 8 !important;
    }
    .slide-enter-content > *:nth-child(9) {
      --enter-stage: 9 !important;
    }
    .slide-enter-content > *:nth-child(10) {
      --enter-stage: 10 !important;
    }
    .slide-enter-content > *:nth-child(11) {
      --enter-stage: 11 !important;
    }
    .slide-enter-content > *:nth-child(12) {
      --enter-stage: 12 !important;
    }
    .slide-enter-content > *:nth-child(13) {
      --enter-stage: 13 !important;
    }
    .slide-enter-content > *:nth-child(14) {
      --enter-stage: 14 !important;
    }
    .slide-enter-content > *:nth-child(15) {
      --enter-stage: 15 !important;
    }
    .slide-enter-content > *:nth-child(16) {
      --enter-stage: 16 !important;
    }
    .slide-enter-content > *:nth-child(17) {
      --enter-stage: 17 !important;
    }
    .slide-enter-content > *:nth-child(18) {
      --enter-stage: 18 !important;
    }
    .slide-enter-content > *:nth-child(19) {
      --enter-stage: 19 !important;
    }
    .slide-enter-content > *:nth-child(20) {
      --enter-stage: 20 !important;
    }
  }
</style>
